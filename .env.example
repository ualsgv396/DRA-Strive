# Copia este archivo a `.env` y ajusta los valores segun tu entorno.
# El archivo `.env` esta ignorado por git y nunca debe subirse al repositorio.

# --- MySQL ---
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=strive_db
MYSQL_USER=gymuser
MYSQL_PASSWORD=gympass

# --- Backend (Spring Boot) ---
# El host `mysql` es el nombre del servicio en docker-compose.
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/strive_db
SPRING_DATASOURCE_USERNAME=gymuser
SPRING_DATASOURCE_PASSWORD=gympass

# Secreto JWT en base64 (cambiar en produccion)
APP_JWT_SECRET=YzJWeWRtbGpaUzF6YldGeWRDMXpkSEpwZG1VdFkyOXVaR2x1WjI1bGN3PT0=
APP_JWT_EXPIRATION_MS=86400000

# --- Frontend ---
# URL a la que el navegador llamara al backend.
VITE_API_URL=http://localhost:8080/api
